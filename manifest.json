{
  "manifest_version": 3,
  "name": "黑马总裁 Label",
  "version": "2.1.0",
  "description": "黑马总裁 Label 新标签页，支持搜索、多面板、壁纸、备忘录、拖拽整理和数据导入导出。",
  "author": "黑马总裁 Label",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "storage",
    "bookmarks"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://www.baidu.com/*",
    "https://www.google.com/*",
    "https://www.bing.com/*",
    "https://www.sogou.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "黑马总裁 Label",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
